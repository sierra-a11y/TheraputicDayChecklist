let nextId = 200;
let currentTab = 'all';
const secOpen = {};
Object.keys(CATS).forEach(k => { secOpen[k] = true; });
['overdue','urgent','soon','upcoming'].forEach(k => { secOpen['dl_'+k] = true; });

// ─────────────────────────────────────────────────────────────────────────────
// UTILS
// ─────────────────────────────────────────────────────────────────────────────
function daysUntil(due) {
  if (!due || due === 'ongoing') return null;
  const d = new Date(due), n = new Date();
  n.setHours(0,0,0,0);
  return Math.ceil((d - n) / 86400000);
}
function fmtDate(due) {
  if (!due || due === 'ongoing') return 'Ongoing';
  return new Date(due).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
}
function priorityTag(p) {
  if (p === 'critical') return '<span class="tag tag-crit">Critical</span>';
  if (p === 'high')     return '<span class="tag tag-high">High</span>';
  return '<span class="tag tag-med">Medium</span>';
}
function dueTag(due) {
  if (!due) return '';
  if (due === 'ongoing') return '<span class="due-label">Ongoing</span>';
  const d = daysUntil(due);
  if (d === null) return '';
  if (d < 0)  return `<span class="due-label due-urgent">Overdue ${Math.abs(d)}d</span>`;
  if (d < 14) return `<span class="due-label due-urgent">Due in ${d}d</span>`;
  if (d < 60) return `<span class="due-label due-warn">Due in ${d}d</span>`;
  return `<span class="due-label">${fmtDate(due)}</span>`;
}

// ─────────────────────────────────────────────────────────────────────────────
// STATS
// ─────────────────────────────────────────────────────────────────────────────
function updateStats() {
  const total = items.length;
  const done  = items.filter(i => i.done).length;
  const pct   = total ? Math.round(done / total * 100) : 0;
  const crit  = items.filter(i => !i.done && i.priority === 'critical').length;
  document.getElementById('cnt-done').textContent  = done;
  document.getElementById('cnt-open').textContent  = total - done;
  document.getElementById('cnt-crit').textContent  = crit;
  document.getElementById('cnt-total').textContent = total;
  document.getElementById('prog-pct').textContent  = pct + '%';
  document.getElementById('prog-fill').style.width = pct + '%';
  const chip = document.getElementById('status-chip');
  if (pct >= 100) { chip.textContent = '✅ Compliant'; chip.className = 'chip chip-green'; }
  else if (pct >= 50) { chip.textContent = '🔶 In Progress'; chip.className = 'chip chip-amber'; }
  else { chip.textContent = '🔴 Pre-Approval'; chip.className = 'chip chip-red'; }
  // Sidebar badges
  Object.keys(CATS).forEach(cat => {
    const open = items.filter(i => i.cat === cat && !i.done).length;
    const el = document.getElementById('sb-' + cat);
    if (el) { el.textContent = open; el.className = 'sb-badge' + (open > 0 ? ' red' : ''); }
  });
  const allOpen = items.filter(i => !i.done).length;
  const sbAll = document.getElementById('sb-all');
  if (sbAll) sbAll.textContent = allOpen;
  const urgentCount = items.filter(i => !i.done && i.due && i.due !== 'ongoing' && daysUntil(i.due) !== null && daysUntil(i.due) < 60).length;
  const sbDl = document.getElementById('sb-deadlines');
  if (sbDl) sbDl.textContent = urgentCount > 0 ? urgentCount : '✓';
  // Status chips
  const chips = document.getElementById('status-chips');
  const phases = [
    {label:'Business formation', test: i => i.cat==='legal' && i.id===60},
    {label:'ISBE application submitted', test: i => i.id===1},
    {label:'Facility ready', test: i => i.cat==='facility'},
    {label:'Staff hired & cleared', test: i => i.cat==='staff'},
    {label:'ISBE approval received', test: i => i.id===89 || i.id===90},
  ];
  chips.innerHTML = phases.map(ph => {
    const relevant = items.filter(ph.test);
    const allDone = relevant.length > 0 && relevant.every(i => i.done);
    return `<span class="chip ${allDone ? 'chip-green' : 'chip-gray'}">${allDone ? '✓' : '○'} ${ph.label}</span>`;
  }).join('');
}

// ─────────────────────────────────────────────────────────────────────────────
// RENDER
// ─────────────────────────────────────────────────────────────────────────────
function showTab(t) {
  currentTab = t;
  document.querySelectorAll('.sb-item').forEach(el => el.classList.remove('active'));
  const active = document.getElementById('tab-' + t);
  if (active) active.classList.add('active');
  document.getElementById('toolbar').style.display = t === 'deadlines' ? 'none' : 'flex';
  render();
}

function filteredItems() {
  const q  = (document.getElementById('search')?.value || '').toLowerCase();
  const fs = document.getElementById('f-status')?.value || '';
  const fp = document.getElementById('f-priority')?.value || '';
  return items.filter(i => {
    if (currentTab !== 'all' && currentTab !== 'deadlines' && i.cat !== currentTab) return false;
    if (q && !i.title.toLowerCase().includes(q) && !i.note.toLowerCase().includes(q) && !i.ref.toLowerCase().includes(q)) return false;
    if (fs === 'done' && !i.done) return false;
    if (fs === 'pending' && i.done) return false;
    if (fp && i.priority !== fp) return false;
    return true;
  });
}

function render() {
  updateStats();
  if (currentTab === 'deadlines') { renderDeadlines(); return; }
  const content = document.getElementById('content');
  const catKeys = currentTab === 'all' ? Object.keys(CATS) : [currentTab];
  const visible = filteredItems();
  let html = '';
  catKeys.forEach(cat => {
    const catItems = visible.filter(i => i.cat === cat);
    if (!catItems.length && currentTab !== 'all') return;
    if (!catItems.length) return;
    const C = CATS[cat];
    const done = catItems.filter(i => i.done).length;
    const pct  = catItems.length ? Math.round(done/catItems.length*100) : 0;
    const isOpen = secOpen[cat];
    html += `<div class="section">
      <div class="sec-hdr" onclick="toggleSec('${cat}')">
        <span class="sec-icon">${C.icon}</span>
        <span class="sec-title">${C.label}</span>
        <div class="sec-right">
          <span class="sec-ref">${C.ref}</span>
          <span class="sec-prog-txt">${done}/${catItems.length}</span>
          <span class="sec-chevron ${isOpen?'open':''}">▼</span>
        </div>
      </div>
      <div class="sec-mini-bar"><div class="sec-mini-fill" style="width:${pct}%"></div></div>
      ${isOpen ? `<div class="items-wrap">${catItems.map(itemRow).join('')}</div>` : ''}
    </div>`;
  });
  content.innerHTML = html || '<div class="empty">No items match your filters.</div>';
}

function itemRow(item) {
  return `<div class="item ${item.done?'done':''}" id="item-${item.id}">
    <div class="cb-wrap">
      <div class="cb ${item.done?'done':''}" onclick="toggle(${item.id})"></div>
    </div>
    <div class="i-body">
      <div class="i-title" onclick="openDetail(${item.id})">${item.title}</div>
      <div class="i-meta">
        ${priorityTag(item.priority)}
        <span class="tag tag-ref">${item.ref}</span>
        ${dueTag(item.due)}
        ${item.file ? '<span class="tag tag-file">📎 Doc attached</span>' : ''}
      </div>
      ${item.note ? `<div class="i-note">${item.note}</div>` : ''}
    </div>
    <div class="i-right">
      ${dueTag(item.due)}
      <label class="attach-btn">
        <input type="file" style="display:none" onchange="attachFile(${item.id},this)">
        ${item.file ? '✓ Update' : '📎 Attach'}
      </label>
    </div>
  </div>`;
}

function renderDeadlines() {
  const open = items.filter(i => !i.done && i.due && i.due !== 'ongoing');
  open.sort((a,b) => new Date(a.due) - new Date(b.due));
  const groups = { overdue:[], urgent:[], soon:[], upcoming:[] };
  open.forEach(i => {
    const d = daysUntil(i.due);
    if (d === null) return;
    if (d < 0)  groups.overdue.push(i);
    else if (d < 30)  groups.urgent.push(i);
    else if (d < 90)  groups.soon.push(i);
    else groups.upcoming.push(i);
  });
  const cfg = {
    overdue:  {label:'⛔ Overdue',         col:'red'},
    urgent:   {label:'🔴 Due within 30 days', col:'red'},
    soon:     {label:'🟡 Due within 90 days', col:'amber'},
    upcoming: {label:'🟢 Upcoming',          col:'green'},
  };
  let html = '';
  Object.keys(cfg).forEach(g => {
    if (!groups[g].length) return;
    const isOpen = secOpen['dl_'+g] !== false;
    html += `<div class="section">
      <div class="sec-hdr" onclick="toggleSecDl('${g}')">
        <span class="sec-title">${cfg[g].label}</span>
        <div class="sec-right">
          <span class="sec-prog-txt">${groups[g].length} items</span>
          <span class="sec-chevron ${isOpen?'open':''}">▼</span>
        </div>
      </div>
      ${isOpen ? `<div class="items-wrap">${groups[g].map(i => {
        const d = daysUntil(i.due);
        const label = d < 0 ? `${Math.abs(d)}d overdue` : d === 0 ? 'Today' : d === 1 ? 'Tomorrow' : `${d} days`;
        const col = d < 0 || d < 30 ? 'red' : d < 90 ? 'amber' : 'green';
        return `<div class="dl-item">
          <div class="dl-dot ${col}"></div>
          <div class="dl-body">
            <div class="dl-title" onclick="openDetail(${i.id})" style="cursor:pointer">${i.title}</div>
            <div class="dl-sub">${i.ref} &nbsp;·&nbsp; ${fmtDate(i.due)} &nbsp;·&nbsp; ${CATS[i.cat]?.label||i.cat}</div>
          </div>
          <div class="dl-days ${col}">${label}</div>
        </div>`;
      }).join('')}</div>` : ''}
    </div>`;
  });
  document.getElementById('content').innerHTML = html || '<div class="empty">🎉 No upcoming deadlines — all items completed!</div>';
}

function toggleSec(cat)     { secOpen[cat] = !secOpen[cat]; render(); }
function toggleSecDl(g)     { secOpen['dl_'+g] = !secOpen['dl_'+g]; renderDeadlines(); }

// ─────────────────────────────────────────────────────────────────────────────
// ACTIONS
// ─────────────────────────────────────────────────────────────────────────────
function toggle(id) {
  const item = items.find(i => i.id === id);
  if (item) { item.done = !item.done; render(); }
}
function attachFile(id, input) {
  const item = items.find(i => i.id === id);
  if (item && input.files.length) { item.file = input.files[0].name; render(); }
}
function markAllVisible() {
  filteredItems().forEach(i => { i.done = true; });
  render();
}
function markCriticalDone() {
  items.filter(i => i.priority === 'critical').forEach(i => { i.done = true; });
  render();
}
function resetAll() {
  if (confirm('Reset all items to incomplete?')) {
    items.forEach(i => { i.done = false; i.file = null; });
    render();
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────────────────────────────────────────
let detailId = null;
function overlayClick(e) { if (e.target.id === 'overlay') closeModal(); }
function closeModal() { document.getElementById('overlay').classList.remove('show'); }

function openDetail(id) {
  detailId = id;
  const item = items.find(i => i.id === id);
  if (!item) return;
  const C = CATS[item.cat] || {};
  document.getElementById('modal').innerHTML = `
    <div class="modal-hdr">
      <h3>${C.icon||''} ${item.title}</h3>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="detail-row"><span class="detail-label">Category</span><span class="detail-val">${C.label||item.cat}</span></div>
    <div class="detail-row"><span class="detail-label">ISBE Reference</span><span class="detail-val"><strong>${item.ref}</strong></span></div>
    <div class="detail-row"><span class="detail-label">Priority</span><span class="detail-val">${priorityTag(item.priority)}</span></div>
    <div class="detail-row"><span class="detail-label">Due Date</span><span class="detail-val">${fmtDate(item.due)}</span></div>
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-val">${item.done ? '<span class="tag tag-file">✅ Completed</span>' : '<span class="tag tag-med">⬜ Pending</span>'}</span></div>
    <div class="detail-row"><span class="detail-label">Document</span><span class="detail-val">${item.file ? `<span class="tag tag-file">📎 ${item.file}</span>` : 'No document attached yet'}</span></div>
    <div class="detail-row" style="align-items:flex-start"><span class="detail-label">Notes</span><span class="detail-val">${item.note || 'No additional notes.'}</span></div>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem">
      <button class="btn btn-primary" onclick="toggleFromModal(${id})">${item.done ? '↩ Mark pending' : '✓ Mark complete'}</button>
      <label class="btn"><input type="file" style="display:none" onchange="attachFromModal(this)">📎 Attach document</label>
      <button class="btn" style="color:var(--crit);border-color:#FFCDD2" onclick="deleteItem(${id})">🗑 Delete</button>
    </div>
    <div class="modal-footer"><button class="btn" onclick="closeModal()">Close</button></div>`;
  document.getElementById('overlay').classList.add('show');
}

function toggleFromModal(id) { toggle(id); closeModal(); }
function attachFromModal(input) {
  const item = items.find(i => i.id === detailId);
  if (item && input.files.length) { item.file = input.files[0].name; openDetail(detailId); render(); }
}
function deleteItem(id) {
  if (confirm('Delete this compliance item?')) {
    items = items.filter(i => i.id !== id);
    closeModal(); render();
  }
}

function openAddModal() {
  document.getElementById('modal').innerHTML = `
    <div class="modal-hdr">
      <h3>➕ Add Compliance Item</h3>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="field"><label>Title *</label><input id="m-title" placeholder="e.g., Draft behavioral intervention policy"></div>
    <div class="field"><label>Category</label><select id="m-cat">${Object.entries(CATS).map(([k,v])=>`<option value="${k}">${v.icon} ${v.label}</option>`).join('')}</select></div>
    <div class="field"><label>Priority</label><select id="m-pri"><option value="critical">🔴 Critical</option><option value="high">🟡 High</option><option value="medium">Medium</option></select></div>
    <div class="field"><label>Due Date</label><input type="date" id="m-due"></div>
    <div class="field"><label>ISBE / Legal Reference</label><input id="m-ref" placeholder="e.g., §401.10(a)(1)"></div>
    <div class="field"><label>Notes / Instructions</label><textarea id="m-note" placeholder="Details, who is responsible, links to forms, etc."></textarea></div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="addItem()">Add Item</button>
    </div>`;
  document.getElementById('overlay').classList.add('show');
}

function addItem() {
  const t = (document.getElementById('m-title').value || '').trim();
  if (!t) { alert('Please enter a title.'); return; }
  items.push({
    id: nextId++,
    cat: document.getElementById('m-cat').value,
    title: t,
    priority: document.getElementById('m-pri').value,
    due: document.getElementById('m-due').value || null,
    ref: document.getElementById('m-ref').value || 'Custom',
    note: document.getElementById('m-note').value || '',
    done: false,
    file: null
  });
  closeModal(); render();
}

// ─────────────────────────────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────────────────────────────
render();
</script>
</body>
</html>
