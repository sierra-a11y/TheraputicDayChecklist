<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Part 401 Compliance Filing System — Illinois TDS</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0D1B2A;--navy2:#1B2A4A;--accent:#1565C0;--teal:#00897B;
  --gold:#F9A825;--crit:#C62828;--high:#E65100;--ok:#2E7D32;
  --bg:#F8F9FA;--card:#FFFFFF;--border:#DEE2E6;--text:#212529;
  --text2:#6C757D;--text3:#ADB5BD;
  --bg-red:#FFEBEE;--tx-red:#B71C1C;
  --bg-amber:#FFF8E1;--tx-amber:#E65100;
  --bg-green:#E8F5E9;--tx-green:#1B5E20;
  --bg-blue:#E3F2FD;--tx-blue:#0D47A1;
  --bg-gray:#F5F5F5;--tx-gray:#424242;
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

/* HEADER */
.top-bar{background:var(--navy);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem}
.top-bar h1{color:#fff;font-size:17px;font-weight:600}
.top-bar p{color:#90CAF9;font-size:12px;margin-top:2px}
.header-actions{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap}

/* LAYOUT */
.shell{display:flex;height:calc(100vh - 60px)}
.sidebar{width:230px;min-width:230px;background:var(--navy2);display:flex;flex-direction:column;overflow-y:auto}
.main{flex:1;overflow-y:auto;padding:1.25rem}

/* SIDEBAR */
.sb-label{font-size:10px;font-weight:700;color:#90CAF9;padding:.75rem 1rem .25rem;letter-spacing:.08em;text-transform:uppercase}
.sb-item{display:flex;align-items:center;gap:.6rem;padding:.55rem 1rem;cursor:pointer;border-left:3px solid transparent;transition:all .15s;color:#CBD5E1;font-size:13px}
.sb-item:hover{background:rgba(255,255,255,.07);color:#fff}
.sb-item.active{background:rgba(255,255,255,.12);border-left-color:#90CAF9;color:#fff;font-weight:500}
.sb-icon{font-size:15px;width:20px;text-align:center}
.sb-badge{margin-left:auto;background:rgba(255,255,255,.15);color:#90CAF9;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px}
.sb-badge.red{background:var(--crit);color:#fff}
.sb-divider{height:0.5px;background:rgba(255,255,255,.1);margin:.5rem 0}

/* STATS BAR */
.stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-bottom:1rem}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:.85rem 1rem}
.stat-num{font-size:24px;font-weight:700;line-height:1}
.stat-lbl{font-size:11px;color:var(--text2);margin-top:4px}
.stat-ok .stat-num{color:var(--ok)}
.stat-red .stat-num{color:var(--crit)}
.stat-amber .stat-num{color:var(--high)}
.stat-blue .stat-num{color:var(--accent)}

/* PROGRESS */
.prog-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:1rem 1.25rem;margin-bottom:1rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.6rem}
.prog-top h2{font-size:14px;font-weight:600}
.prog-pct{font-size:14px;font-weight:700}
.prog-bar{height:10px;background:#E9ECEF;border-radius:5px;overflow:hidden}
.prog-fill{height:100%;border-radius:5px;background:linear-gradient(90deg,var(--accent),var(--teal));transition:width .5s ease}
.status-chips{display:flex;gap:.5rem;margin-top:.6rem;flex-wrap:wrap}
.chip{font-size:11px;font-weight:600;padding:3px 10px;border-radius:12px}
.chip-red{background:var(--bg-red);color:var(--tx-red)}
.chip-amber{background:var(--bg-amber);color:var(--tx-amber)}
.chip-green{background:var(--bg-green);color:var(--tx-green)}
.chip-blue{background:var(--bg-blue);color:var(--tx-blue)}
.chip-gray{background:var(--bg-gray);color:var(--tx-gray)}

/* ALERT */
.alert{background:var(--bg-amber);border:1px solid #FFCC02;border-radius:8px;padding:.75rem 1rem;margin-bottom:1rem;font-size:12.5px;color:var(--tx-amber);display:flex;gap:.5rem;line-height:1.5}

/* TOOLBAR */
.toolbar{display:flex;gap:.5rem;margin-bottom:.75rem;flex-wrap:wrap;align-items:center}
.toolbar input{flex:1;min-width:160px;font-size:13px;padding:7px 12px;border:1px solid var(--border);border-radius:7px;background:#fff;color:var(--text)}
.toolbar select{font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:7px;background:#fff;color:var(--text)}
.btn{font-size:12px;font-weight:600;padding:7px 14px;border-radius:7px;border:1px solid var(--border);background:#fff;color:var(--text);cursor:pointer;white-space:nowrap;transition:all .15s}
.btn:hover{background:#F1F3F5}
.btn-primary{background:var(--navy);color:#fff;border-color:var(--navy)}
.btn-primary:hover{background:var(--navy2)}
.btn-teal{background:var(--teal);color:#fff;border-color:var(--teal)}
.btn-teal:hover{opacity:.9}

/* SECTION ACCORDION */
.section{background:var(--card);border:1px solid var(--border);border-radius:10px;margin-bottom:.625rem;overflow:hidden}
.sec-hdr{display:flex;align-items:center;gap:.75rem;padding:.85rem 1.1rem;cursor:pointer;user-select:none;transition:background .1s}
.sec-hdr:hover{background:#F8F9FA}
.sec-icon{font-size:16px;width:22px;text-align:center}
.sec-title{font-size:13px;font-weight:600;color:var(--text);flex:1}
.sec-right{display:flex;align-items:center;gap:.5rem}
.sec-ref{font-size:10px;background:#EEF2FF;color:#4338CA;border-radius:8px;padding:2px 8px;font-weight:600}
.sec-prog-txt{font-size:12px;color:var(--text2)}
.sec-chevron{font-size:11px;color:var(--text3);transition:transform .2s}
.sec-chevron.open{transform:rotate(180deg)}
.sec-mini-bar{height:3px;background:#E9ECEF;margin:0 1.1rem .6rem}
.sec-mini-fill{height:100%;background:var(--teal);border-radius:2px;transition:width .3s}

/* ITEMS */
.items-wrap{padding:0 .5rem .5rem}
.item{display:flex;align-items:flex-start;gap:.75rem;padding:.65rem .75rem;border-radius:8px;transition:background .1s;cursor:default;border-bottom:1px solid #F1F3F5}
.item:last-child{border-bottom:none}
.item:hover{background:#FAFAFA}
.item.done .i-title{color:var(--text3);text-decoration:line-through}
.cb-wrap{flex-shrink:0;padding-top:2px}
.cb{width:18px;height:18px;border-radius:5px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;flex-shrink:0}
.cb:hover{border-color:var(--teal)}
.cb.done{background:var(--teal);border-color:var(--teal)}
.cb.done::after{content:"✓";color:#fff;font-size:11px;font-weight:700;line-height:1}
.i-body{flex:1;min-width:0}
.i-title{font-size:13px;color:var(--text);line-height:1.45;cursor:pointer}
.i-title:hover{color:var(--accent)}
.i-meta{display:flex;gap:5px;margin-top:5px;flex-wrap:wrap;align-items:center}
.tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px}
.tag-crit{background:var(--bg-red);color:var(--tx-red)}
.tag-high{background:var(--bg-amber);color:var(--tx-amber)}
.tag-med{background:var(--bg-gray);color:var(--tx-gray)}
.tag-ref{background:#EEF2FF;color:#4338CA}
.tag-file{background:var(--bg-green);color:var(--tx-green)}
.i-note{font-size:11.5px;color:var(--text2);margin-top:4px;line-height:1.5}
.i-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0}
.due-label{font-size:11px;color:var(--text3)}
.due-urgent{color:var(--crit)!important;font-weight:600}
.due-warn{color:var(--high)!important;font-weight:600}
.attach-btn{font-size:11px;padding:3px 9px;border:1px solid var(--border);border-radius:6px;background:#fff;color:var(--text2);cursor:pointer}
.attach-btn:hover{background:#F1F3F5}

/* DEADLINE VIEW */
.dl-group{margin-bottom:1rem}
.dl-label{font-size:11px;font-weight:700;color:var(--text2);letter-spacing:.06em;text-transform:uppercase;padding:.5rem 0 .4rem}
.dl-item{display:flex;align-items:flex-start;gap:.75rem;padding:.6rem .75rem;background:var(--card);border:1px solid var(--border);border-radius:8px;margin-bottom:.4rem}
.dl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px}
.dl-dot.red{background:var(--crit)}
.dl-dot.amber{background:var(--high)}
.dl-dot.green{background:var(--ok)}
.dl-body{flex:1}
.dl-title{font-size:13px;color:var(--text);line-height:1.4}
.dl-sub{font-size:11px;color:var(--text2);margin-top:2px}
.dl-days{font-size:12px;font-weight:700;flex-shrink:0}
.dl-days.red{color:var(--crit)}
.dl-days.amber{color:var(--high)}
.dl-days.green{color:var(--ok)}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;z-index:1000;padding:1rem}
.overlay.show{display:flex}
.modal{background:#fff;border-radius:12px;padding:1.5rem;max-width:460px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.2);max-height:92vh;overflow-y:auto}
.modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.modal h3{font-size:15px;font-weight:700;color:var(--text)}
.modal-close{background:none;border:none;font-size:20px;color:var(--text2);cursor:pointer;line-height:1;padding:0 4px}
.field{margin-bottom:.85rem}
.field label{display:block;font-size:12px;font-weight:600;color:var(--text2);margin-bottom:4px}
.field input,.field textarea,.field select{width:100%;font-size:13px;padding:8px 10px;border:1px solid var(--border);border-radius:7px;color:var(--text);background:#fff}
.field textarea{min-height:80px;resize:vertical}
.detail-row{display:flex;gap:.5rem;margin-bottom:.5rem;font-size:13px;align-items:flex-start}
.detail-label{font-weight:600;color:var(--text2);min-width:90px;flex-shrink:0}
.detail-val{color:var(--text);line-height:1.5;flex:1}
.modal-footer{display:flex;gap:.5rem;justify-content:flex-end;margin-top:1rem;padding-top:.75rem;border-top:1px solid var(--border)}
.empty{text-align:center;padding:2.5rem;color:var(--text2);font-size:13px}

/* EXPORT */
@media print{
  .sidebar,.toolbar,.header-actions,.attach-btn,.cb{display:none!important}
  .shell{display:block;height:auto}
  .main{padding:.5rem}
  .section{page-break-inside:avoid}
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <div>
    <h1>📋 Part 401 Compliance Filing System</h1>
    <p>Illinois Therapeutic Day School — ISBE Nonpublic Special Education Program</p>
  </div>
  <div class="header-actions">
    <span class="chip chip-red" id="status-chip">Pre-Approval</span>
    <button class="btn btn-teal" onclick="openAddModal()">+ Add Item</button>
    <button class="btn btn-primary" onclick="window.print()">🖨 Print / Export</button>
  </div>
</div>

<div class="shell">

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sb-label">Navigation</div>
  <div class="sb-item active" onclick="showTab('all')" id="tab-all"><span class="sb-icon">🏠</span>All Items<span class="sb-badge" id="sb-all">0</span></div>
  <div class="sb-divider"></div>
  <div class="sb-label">Compliance Areas</div>
  <div class="sb-item" onclick="showTab('application')" id="tab-application"><span class="sb-icon">📋</span>Application Docs<span class="sb-badge" id="sb-application">0</span></div>
  <div class="sb-item" onclick="showTab('facility')" id="tab-facility"><span class="sb-icon">🏗️</span>Facility &amp; Safety<span class="sb-badge" id="sb-facility">0</span></div>
  <div class="sb-item" onclick="showTab('staff')" id="tab-staff"><span class="sb-icon">👩‍🏫</span>Staffing<span class="sb-badge" id="sb-staff">0</span></div>
  <div class="sb-item" onclick="showTab('legal')" id="tab-legal"><span class="sb-icon">⚖️</span>Legal &amp; Assurances<span class="sb-badge" id="sb-legal">0</span></div>
  <div class="sb-item" onclick="showTab('records')" id="tab-records"><span class="sb-icon">🗂️</span>Records &amp; Contracts<span class="sb-badge" id="sb-records">0</span></div>
  <div class="sb-item" onclick="showTab('operational')" id="tab-operational"><span class="sb-icon">⚙️</span>Operational<span class="sb-badge" id="sb-operational">0</span></div>
  <div class="sb-divider"></div>
  <div class="sb-label">Views</div>
  <div class="sb-item" onclick="showTab('deadlines')" id="tab-deadlines"><span class="sb-icon">📅</span>Deadlines<span class="sb-badge red" id="sb-deadlines">!</span></div>
  <div class="sb-divider"></div>
  <div class="sb-label">Quick Actions</div>
  <div class="sb-item" onclick="markCriticalDone()" style="cursor:pointer"><span class="sb-icon">🎯</span>Mark Critical Done</div>
  <div class="sb-item" onclick="resetAll()" style="cursor:pointer"><span class="sb-icon">↺</span>Reset All</div>
</div>

<!-- MAIN -->
<div class="main" id="main">

  <!-- Stats -->
  <div class="stats-bar">
    <div class="stat-card stat-ok"><div class="stat-num" id="cnt-done">0</div><div class="stat-lbl">✅ Completed</div></div>
    <div class="stat-card stat-red"><div class="stat-num" id="cnt-open">0</div><div class="stat-lbl">⬜ Pending</div></div>
    <div class="stat-card stat-amber"><div class="stat-num" id="cnt-crit">0</div><div class="stat-lbl">🔴 Critical Open</div></div>
    <div class="stat-card stat-blue"><div class="stat-num" id="cnt-total">0</div><div class="stat-lbl">📊 Total Items</div></div>
  </div>

  <!-- Progress -->
  <div class="prog-card">
    <div class="prog-top">
      <h2>Overall Compliance Progress — August 2026 Target</h2>
      <span class="prog-pct" id="prog-pct">0%</span>
    </div>
    <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
    <div class="status-chips" id="status-chips"></div>
  </div>

  <!-- Alert -->
  <div class="alert">
    ⚑ <span><strong>Immediate action required:</strong> Submit your ISBE Intent to Apply today — approval takes 6–12 months and you must open by August 2026. Every item marked <em>Critical</em> must be complete before your ISBE on-site review.</span>
  </div>

  <!-- Toolbar -->
  <div class="toolbar" id="toolbar">
    <input type="text" id="search" placeholder="🔍  Search by title, note, or reference..." oninput="render()">
    <select id="f-status" onchange="render()"><option value="">All statuses</option><option value="pending">Pending</option><option value="done">Completed</option></select>
    <select id="f-priority" onchange="render()"><option value="">All priorities</option><option value="critical">Critical</option><option value="high">High</option><option value="medium">Medium</option></select>
    <button class="btn btn-primary" onclick="markAllVisible()">Mark visible done</button>
  </div>

  <!-- Content area -->
  <div id="content"></div>
</div>
</div>

<!-- MODAL -->
<div class="overlay" id="overlay" onclick="overlayClick(event)">
<div class="modal" id="modal"></div>
</div>

<script>
// ─────────────────────────────────────────────────────────────────────────────
// DATA
// ─────────────────────────────────────────────────────────────────────────────
const CATS = {
  application: {label:'Application Documents',     icon:'📋', ref:'§ 401.10(a)'},
  facility:    {label:'Facility & Safety',          icon:'🏗️', ref:'§ 401.10(a)(4)'},
  staff:       {label:'Staffing & Credentials',     icon:'👩‍🏫', ref:'§ 401.240'},
  legal:       {label:'Legal & Assurances',         icon:'⚖️',  ref:'§ 401.10(a)(5)'},
  records:     {label:'Records & Contracts',        icon:'🗂️', ref:'§ 401.130'},
  operational: {label:'Operational Compliance',     icon:'⚙️',  ref:'§ 401.140'},
};

let items = [
// APPLICATION
{id:1,  cat:'application',title:'Submit Intent to Apply form via ISBE portal',priority:'critical',due:'2026-01-15',ref:'§401.10',note:'First step — do this immediately. ISBE assigns a principal consultant after submission. All subsequent steps depend on this.',done:false,file:null},
{id:2,  cat:'application',title:'Complete ISBE nonpublic special education orientation',priority:'critical',due:'2026-02-28',ref:'§401.10(c)',note:'Mandatory before ISBE makes a final determination. Scheduled by your assigned principal consultant.',done:false,file:null},
{id:3,  cat:'application',title:'Written program description — disability categories and age ranges',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(A)',note:'Specify exact disability categories (e.g., Emotional Disturbance, AUT, OHI) and age range (e.g., 5–21). This determines which students districts can legally place with you.',done:false,file:null},
{id:4,  cat:'application',title:'Written program description — purpose, scope, and all services offered',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(B)',note:'Comprehensive narrative of all educational and related services. Must describe what is offered, how it is delivered, and by whom.',done:false,file:null},
{id:5,  cat:'application',title:'Programmatic outcomes and IEP-aligned data collection plan',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(C)',note:'Describe exactly what data you will collect for each student tied to their IEP goals. ISBE reviews this closely.',done:false,file:null},
{id:6,  cat:'application',title:'Maximum student enrollment capacity statement',priority:'high',due:'2026-03-15',ref:'§401.10(a)(1)(D)',note:'Calculate based on classroom sizes and mandatory 5:1 ratio (or 10:1 with full-time para). This number limits your revenue ceiling.',done:false,file:null},
{id:7,  cat:'application',title:'Program philosophy and LRE reintegration methodology',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(E)',note:'Articulate your therapeutic model and how it systematically works to return students to less restrictive environments. Required element.',done:false,file:null},
{id:8,  cat:'application',title:'Program history, mission statement, and vision statement',priority:'high',due:'2026-03-15',ref:'§401.10(a)(1)(F)',note:'Formal mission and vision documents. If you are new, your mission/vision and founding philosophy suffice.',done:false,file:null},
{id:9,  cat:'application',title:'Instructional approach for each disability eligibility category sought',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(G)',note:'Separate narrative for each category (ED, AUT, SLD, etc.) describing evidence-based instructional methodology used.',done:false,file:null},
{id:10, cat:'application',title:'Related services description — what, how, and by whom',priority:'critical',due:'2026-03-15',ref:'§401.10(a)(1)(H)',note:'List speech-language, OT, social work, counseling, school psychology. Identify employee vs. contractor for each.',done:false,file:null},
{id:11, cat:'application',title:'Labeled floor plan — allocation of space for program use',priority:'critical',due:'2026-04-01',ref:'§401.10(a)(2)(A)',note:'Architect or detailed drawing showing: classrooms, therapy rooms, sensory/de-escalation room, nurse station, admin offices, restrooms, exit routes.',done:false,file:null},
{id:12, cat:'application',title:'Organizational chart — governance, administrative, educational structures',priority:'critical',due:'2026-04-01',ref:'§401.10(a)(2)(B)',note:'Must show: Board/ownership → Administrator → Lead Teachers → Paraprofessionals → Related Services providers.',done:false,file:null},
{id:13, cat:'application',title:'School calendar — 176 attendance days, minimum 5 instructional hours/day',priority:'critical',due:'2026-04-01',ref:'§401.10(a)(3)(A)',note:'Lunch, passing time, and recess excluded from instructional hours. Up to 2 full-day parent-teacher conferences allowed (reduces to 174 days).',done:false,file:null},
{id:14, cat:'application',title:'ESY (Extended School Year) calendar — minimum 120 instructional hours',priority:'high',due:'2026-05-01',ref:'§401.10(a)(3)(B)',note:'Required only if you will offer summer programming. Many TDS students have ESY in their IEPs — plan for this.',done:false,file:null},
{id:15, cat:'application',title:'Staff credentials summary with license numbers for all professional staff',priority:'critical',due:'2026-04-15',ref:'§401.10(a)(8)',note:'Table listing: name, position, license type, license number, endorsement, expiration date. ISBE verifies each one.',done:false,file:null},
{id:16, cat:'application',title:'Related services documentation — employee or contracted provider verification',priority:'critical',due:'2026-04-15',ref:'§401.10(a)(9)',note:'Demonstrate you have access to every related service that may appear on a student IEP — contracts in hand before application.',done:false,file:null},
{id:17, cat:'application',title:'Behavioral intervention policy — written formalized approach',priority:'critical',due:'2026-04-01',ref:'§401.10(a)(10)',note:'Must explicitly list prohibited techniques. Include your crisis de-escalation framework (e.g., CPI/NCI). Cannot use pain-based or any Illinois-banned intervention.',done:false,file:null},

// FACILITY
{id:20, cat:'facility',title:'Office of State Fire Marshal (OSFM) inspection — no violations',priority:'critical',due:'2026-05-01',ref:'§401.10(a)(4)(A)(i)',note:'Report must be no more than 36 months old at time of ISBE approval. Schedule 2–3 months early — OSFM has backlogs.',done:false,file:null},
{id:21, cat:'facility',title:'Local municipality health/occupancy inspection clearance',priority:'critical',due:'2026-05-15',ref:'§401.10(a)(4)(A)(ii)',note:'Must be no more than 12 months old. Obtain after all construction/renovation is complete and before ISBE site visit.',done:false,file:null},
{id:22, cat:'facility',title:'Regional superintendent Life Safety inspection (23 Ill. Adm. Code 180)',priority:'critical',due:'2026-05-15',ref:'§401.10(a)(4)(C)',note:'Covers fire safety, emergency exits, suppression systems. Required for all Illinois facilities under the Health/Life Safety Code for Public Schools.',done:false,file:null},
{id:23, cat:'facility',title:'Certificate of occupancy (new construction or renovation projects)',priority:'critical',due:'2026-05-15',ref:'§401.10(a)(4)(B)',note:'Required in addition to fire inspection if any construction or renovation occurred. Get from local building department.',done:false,file:null},
{id:24, cat:'facility',title:'ADA Title III compliance assessment — entrances, restrooms, classrooms, parking',priority:'critical',due:'2026-06-01',ref:'ADA Title III / 42 USC 12101',note:'Complete formal ADA assessment. All student-accessible areas must be fully accessible. Document in writing for ISBE on-site visit.',done:false,file:null},
